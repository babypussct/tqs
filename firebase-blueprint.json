{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "originalPrice": { "type": "number", "description": "Original price (optional)" },
        "image": { "type": "string", "description": "Image URL" },
        "type": { "type": "string", "description": "Product type (base, expansion, accessory, combo, or custom)" },
        "badge": { "type": "string", "description": "Badge text (optional)" },
        "isExpansion": { "type": "boolean", "description": "Is this an expansion?" },
        "requiresBase": { "type": "boolean", "description": "Does it require the base game?" },
        "specs": { "type": "object", "description": "Technical specifications" },
        "variants": { "type": "object", "description": "Available variants" },
        "isActive": { "type": "boolean", "description": "Is the product active/visible?" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "image", "type", "isActive", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User role" },
        "phone": { "type": "string", "description": "User phone number" },
        "address": { "type": "string", "description": "User default address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of items in the order" },
        "totalAmount": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"], "description": "Order status" },
        "shippingInfo": { "type": "object", "description": "Shipping information" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingInfo", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
